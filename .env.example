# Copy this to .env.local and fill in your values.
# Never commit .env.local to git.

# Web3Forms access key (get yours free at app.web3forms.com)
# The API route uses this server-side — it's never exposed to the browser.
WEB3FORMS_KEY=your_web3forms_access_key_here

# Dashboard protection secret — set a long random string (e.g. openssl rand -hex 32)
# Used to protect /dashboard and /api/reviews from public access
DASHBOARD_SECRET=your_dashboard_secret_here
